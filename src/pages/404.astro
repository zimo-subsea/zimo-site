---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Zimo — Siden finnes ikke">
  <Header />

  <main class="bg-[#05090b] text-white">
    <section class="zimo-shell flex min-h-[70vh] flex-col justify-center py-20">
      <p class="zimo-eyebrow">404</p>
      <h1 class="mt-6 max-w-3xl text-5xl font-semibold tracking-tight md:text-7xl">
        Siden finnes ikke.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/68">
        Lenken kan være gammel, eller siden kan ha flyttet seg mens vi bygger om
        Zimo-nettsiden.
      </p>
      <div class="mt-10 flex flex-col gap-3 sm:flex-row">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-md bg-[#a8fff2] px-6 py-3 text-sm font-semibold text-[#05090b]"
        >
          Til forsiden
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-md border border-white/18 bg-white/5 px-6 py-3 text-sm font-semibold text-white/86"
        >
          Kontakt Zimo
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
