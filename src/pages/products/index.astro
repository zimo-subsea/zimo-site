---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const pillars = [
  {
    title: "Kamera under vann",
    text: "En robust undervannsenhet med enkel elektronikk og GMSL-basert kameraretning.",
  },
  {
    title: "Gateway over vann",
    text: "Topside-enheten tar imot bilde, håndterer videre prosessering og gjør systemet lettere å drifte.",
  },
  {
    title: "Operasjonell flate",
    text: "Live video, opptak, status og support samles i en enkel nettleserbasert arbeidsflate.",
  },
];
---

<BaseLayout
  title="Zimo — System"
  description="Zimo sitt første undervannskamerasystem kombinerer kamera, gateway, live video og enkel drift."
>
  <Header />

  <main id="main-content" class="bg-white text-[#0b1114]">
    <section class="relative overflow-hidden bg-[linear-gradient(180deg,#ffffff_0%,#f6f8f8_100%)]">
      <div class="absolute inset-0 bg-[radial-gradient(900px_420px_at_70%_18%,rgba(34,184,170,0.12),transparent_68%)]"></div>
      <div class="zimo-shell relative grid gap-12 py-20 lg:grid-cols-[1fr_0.9fr] lg:items-center lg:py-28">
        <div>
          <p class="zimo-eyebrow">System</p>
          <h1 class="mt-6 max-w-4xl text-5xl font-semibold leading-tight tracking-tight text-[#071923] md:text-7xl">
            Kamera, gateway og live video i én løsning.
          </h1>
          <p class="mt-7 max-w-2xl text-lg leading-relaxed text-[#516066]">
            Første Zimo-system er laget rundt én praktisk idé: få pålitelig
            visuell kontroll under vann uten at kunden må bygge hele
            kamerakjeden selv.
          </p>
        </div>
        <div class="relative overflow-hidden rounded-2xl border border-[#d9e2e2] bg-white shadow-[0_24px_80px_rgba(7,25,35,0.08)]">
          <img
            src="/products/camera.webp"
            alt="Zimo undervannskamera"
            class="h-[380px] w-full object-contain p-8"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <section class="zimo-shell pb-24">
      <div class="grid gap-5 md:grid-cols-3">
        {pillars.map((item) => (
          <article class="zimo-panel rounded-xl p-6">
            <div class="h-1 w-10 bg-[#22b8aa]"></div>
            <h2 class="mt-6 text-2xl font-semibold text-[#071923]">{item.title}</h2>
            <p class="mt-4 text-sm leading-relaxed text-[#516066]">{item.text}</p>
          </article>
        ))}
      </div>

      <div class="mt-12 rounded-2xl border border-[#d9e2e2] bg-[#f6f8f8] p-7 md:p-10">
        <p class="zimo-eyebrow">Pilotversjon</p>
        <div class="mt-6 grid gap-8 lg:grid-cols-[1fr_0.9fr]">
          <div>
            <h2 class="text-4xl font-semibold tracking-tight text-[#071923]">
              Første system skal valideres sammen med kunde.
            </h2>
            <p class="mt-5 text-base leading-relaxed text-[#516066]">
              Pilotpakken er ikke låst. Den skal formes rundt en konkret
              brukssituasjon, men hovedretningen er undervannskamera, kabel,
              gateway, livevisning, enkel dokumentasjon og support.
            </p>
          </div>
          <div class="grid content-start gap-3 text-sm text-[#516066]">
            <div class="border-l border-[#22b8aa]/70 pl-4">Oppdrett og settefisk</div>
            <div class="border-l border-[#22b8aa]/70 pl-4">Vanninfrastruktur</div>
            <div class="border-l border-[#22b8aa]/70 pl-4">Kai, anlegg og industriell inspeksjon</div>
          </div>
        </div>
        <a
          href="/products/camera"
          class="mt-8 inline-flex items-center justify-center rounded-md bg-[#071923] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#0d2a35]"
        >
          Les om systemretningen
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
