---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const email = "mads.falk@zimo.no";
const mailtoHref =
  "mailto:mads.falk@zimo.no?subject=Pilotdialog%20med%20Zimo&body=Hei%20Mads,%0A%0AJeg%20vil%20gjerne%20snakke%20om%20Zimo%20og%20mulig%20pilot.%0A%0AOrganisasjon:%0ABrukssituasjon:%0AHva%20vi%20%C3%B8nsker%20%C3%A5%20se%20under%20vann:%0A";
---

<BaseLayout
  title="Zimo — Kontakt"
  description="Kontakt Zimo for pilotdialog rundt robuste undervannskamerasystemer."
>
  <Header />

  <main class="bg-[#05090b] text-white">
    <section class="zimo-shell grid gap-12 py-20 lg:grid-cols-[1fr_0.9fr] lg:items-start lg:py-28">
      <div>
        <p class="zimo-eyebrow">Kontakt</p>
        <h1 class="mt-6 text-5xl font-semibold leading-tight tracking-tight md:text-7xl">
          La oss finne ut om Zimo passer deres miljø.
        </h1>
        <p class="mt-7 max-w-2xl text-lg leading-relaxed text-white/70">
          Vi er spesielt interessert i norske miljøer som trenger bedre visuell
          kontroll under vann og kan gi ærlig tilbakemelding i en tidlig pilotfase.
        </p>
      </div>

      <div class="zimo-panel rounded-2xl p-7">
        <p class="text-xs uppercase tracking-[0.22em] text-white/42">Direkte kontakt</p>
        <h2 class="mt-4 text-3xl font-semibold">Mads Falk</h2>
        <p class="mt-2 text-sm text-white/58">Zimo</p>

        <div class="mt-8 grid gap-3">
          <a
            href={mailtoHref}
            class="inline-flex items-center justify-center rounded-md bg-[#a8fff2] px-5 py-3 text-sm font-semibold text-[#05090b] transition hover:bg-[#c6fff7]"
          >
            Send e-post
          </a>
          <button
            type="button"
            data-copy={email}
            class="inline-flex items-center justify-center rounded-md border border-white/18 bg-white/5 px-5 py-3 text-sm font-semibold text-white/86 transition hover:border-white/36 hover:bg-white/9"
          >
            Kopier {email}
          </button>
          <p class="min-h-5 text-xs text-[#a8fff2]" data-copy-feedback aria-live="polite"></p>
        </div>
      </div>
    </section>

    <section class="border-y border-white/10 bg-[#071923]">
      <div class="zimo-shell grid gap-8 py-12 md:grid-cols-3">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-white/42">Bra pilotcase</p>
          <p class="mt-2 text-lg font-semibold">Et konkret undervannsproblem</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-white/42">Første dialog</p>
          <p class="mt-2 text-lg font-semibold">Problem og brukssituasjon</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-white/42">Neste steg</p>
          <p class="mt-2 text-lg font-semibold">Pilotomfang og teknisk fit</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const copyButtons = document.querySelectorAll("[data-copy]");
  const feedback = document.querySelector("[data-copy-feedback]");

  copyButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const value = button.getAttribute("data-copy");
      if (!value) return;
      try {
        await navigator.clipboard.writeText(value);
        if (feedback) {
          feedback.textContent = "E-post kopiert.";
          window.setTimeout(() => {
            feedback.textContent = "";
          }, 2200);
        }
      } catch {
        if (feedback) {
          feedback.textContent = "Kunne ikke kopiere automatisk.";
        }
      }
    });
  });
</script>
