---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const heroImage = "/placeholders/lofoten-fish-farm.jpg";
const farmImage = "/placeholders/aquaculture-aerial.jpg";
const underwaterImage = "/placeholders/underwater-rocks.jpg";

const systemParts = [
  {
    label: "01",
    title: "Undervannsenhet",
    text: "Robust kameramodul for krevende miljøer der inspeksjon normalt krever mer tungvint utstyr.",
  },
  {
    label: "02",
    title: "Toppside-gateway",
    text: "Kabel og gateway samler signal, drift og videre prosessering over vann.",
  },
  {
    label: "03",
    title: "Live arbeidsflate",
    text: "Nettleserbasert live video, opptak, status og dokumentasjon for operatør og beslutningstaker.",
  },
];
---

<BaseLayout
  title="Zimo — Visuell kontroll under vann"
  description="Zimo bygger robuste undervannskamerasystemer for oppdrett, vanninfrastruktur og industriell inspeksjon."
>
  <Header tone="dark" />

  <main id="main-content" class="bg-white text-[#0b1114]">
    <section class="relative min-h-[92vh] overflow-hidden bg-[#071923] text-white">
      <img
        src={heroImage}
        alt="Kystlandskap med fjell og hav"
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(7,25,35,0.78)_0%,rgba(7,25,35,0.18)_38%,rgba(7,25,35,0.82)_100%)]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(7,25,35,0.62)_0%,rgba(7,25,35,0.18)_48%,rgba(7,25,35,0.34)_100%)]"></div>

      <div class="zimo-shell relative flex min-h-[92vh] items-center pb-20 pt-36">
        <div class="max-w-5xl">
          <p class="zimo-mono text-xs font-semibold uppercase tracking-[0.28em] text-[#a8fff2]">Norsk undervannsteknologi</p>
          <h1 class="mt-7 max-w-5xl text-5xl font-semibold leading-[0.98] text-white sm:text-6xl md:text-7xl lg:text-8xl">
            Kontroll på det som skjer
            <span class="text-[#a8fff2]">under overflaten.</span>
          </h1>
          <p class="mt-8 max-w-2xl text-lg leading-relaxed text-white/76 md:text-xl">
            Zimo kombinerer undervannskamera, toppside-gateway, live video,
            opptak og enkel drift i ett robust system for krevende maritime og
            industrielle miljøer.
          </p>
          <div class="mt-10 flex flex-col gap-5 sm:flex-row sm:items-center">
            <a
              href="/contact"
              class="inline-flex cursor-pointer items-center justify-center rounded-sm bg-white px-6 py-3.5 text-sm font-semibold text-[#071923] transition-colors duration-200 hover:bg-[#f97316] hover:text-white"
            >
              Start pilotdialog
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="zimo-shell grid gap-8 py-10 md:grid-cols-3">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-[#516066]">Fokus</p>
          <p class="mt-2 text-lg font-semibold text-[#071923]">Pilotklar kundeverdi</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-[#516066]">Arkitektur</p>
          <p class="mt-2 text-lg font-semibold text-[#071923]">Kamera under vann, gateway over vann</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-[#516066]">Retning</p>
          <p class="mt-2 text-lg font-semibold text-[#071923]">Robust, servicevennlig og EMI-bevisst</p>
        </div>
      </div>
    </section>

    <section id="system" class="bg-white py-24">
      <div class="zimo-shell">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
          <div>
            <p class="zimo-eyebrow">Hva vi bygger</p>
            <h2 class="mt-5 max-w-2xl text-4xl font-semibold tracking-tight text-[#071923] md:text-6xl">
              En praktisk kamerakjede for beslutninger under vann.
            </h2>
          </div>
          <div class="max-w-2xl lg:justify-self-end">
            <p class="text-lg leading-relaxed text-[#516066]">
              Kameraet gir bildet. Gatewayen og programvaren gjør det mulig å
              se, dokumentere og dele funn uten at kunden må bygge hele
              kamerakjeden selv.
            </p>
            <a
              href="https://docs.zimo.no/"
              target="_blank"
              rel="noreferrer"
              class="mt-7 inline-flex cursor-pointer items-center gap-3 border-b border-[#0d776f]/45 pb-1 text-sm font-semibold text-[#0d776f] transition-colors duration-200 hover:border-[#071923] hover:text-[#071923]"
            >
              Les tekniske dokumenter
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <div class="mt-14 grid gap-px overflow-hidden rounded-sm border border-[#d9e2e2] bg-[#d9e2e2] lg:grid-cols-3">
          {systemParts.map((part) => (
            <article class="bg-[#f8fbfb] p-7 transition-colors duration-200 hover:bg-white">
              <p class="zimo-mono text-xs font-semibold text-[#0d776f]">{part.label}</p>
              <h3 class="mt-8 text-2xl font-semibold tracking-tight text-[#071923]">
                {part.title}
              </h3>
              <p class="mt-4 text-sm leading-relaxed text-[#516066]">
                {part.text}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="grid bg-[#071923] text-white lg:grid-cols-2">
      <div class="relative min-h-[520px] overflow-hidden">
        <img
          src={farmImage}
          alt="Fiskemerder sett fra luften"
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-[#071923]/24"></div>
      </div>

      <div class="px-5 py-20 sm:px-8 lg:px-16 lg:py-24">
          <p class="zimo-mono text-xs font-semibold uppercase tracking-[0.28em] text-[#a8fff2]">Designfilosofi</p>
        <h2 class="mt-5 max-w-2xl text-4xl font-semibold tracking-tight md:text-6xl">
          Mindre elektronikk under vann. Mer kontroll på toppen.
        </h2>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-white/72">
          Første systemretning holder undervannsenheten enkel og robust. Kameraet
          sender rådata til en toppside-gateway, der bilde, opptak, support og
          drift håndteres.
        </p>
        <div class="mt-10 grid gap-5 text-sm text-white/68">
          <div class="border-l border-[#a8fff2]/70 pl-5">
            Undervannsenheten holdes enkel, servicevennlig og robust i møte med
            krevende maritime miljøer.
          </div>
          <div class="border-l border-[#a8fff2]/70 pl-5">
            Systemet utvikles for robusthet, servicevennlighet og høy
            EMI-resistens som designmål.
          </div>
          <div class="border-l border-[#a8fff2]/70 pl-5">
            Produktet formes videre gjennom pilotkunder og reelle bruksmiljøer.
          </div>
        </div>
      </div>
    </section>

    <section class="grid bg-white lg:grid-cols-[0.95fr_1.05fr]">
      <div class="px-5 py-20 sm:px-8 lg:px-16 lg:py-24">
        <p class="zimo-eyebrow">Live bilde</p>
        <h2 class="mt-5 max-w-2xl text-4xl font-semibold tracking-tight text-[#071923] md:text-6xl">
          Fra uklart problem til delbart beslutningsgrunnlag.
        </h2>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[#516066]">
          Zimo skal gjøre undervannsinspeksjon lettere å bruke i hverdagen:
          operatører får bilde, opptak og status uten tunge spesialoppsett.
        </p>
      </div>
      <div class="relative min-h-[460px] overflow-hidden">
        <img
          src={underwaterImage}
          alt="Undervannsmiljø som placeholder"
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(255,255,255,0.2),rgba(255,255,255,0))]"></div>
      </div>
    </section>

    <section id="pilot" class="relative overflow-hidden bg-[#071923] text-white">
      <div class="zimo-shell relative grid gap-10 py-24 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div>
          <p class="zimo-mono text-xs font-semibold uppercase tracking-[0.28em] text-[#a8fff2]">Pilotfase</p>
          <h2 class="mt-5 text-4xl font-semibold tracking-tight md:text-6xl">
            Vi søker første pilotmiljø.
          </h2>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-white/72">
            Zimo er i tidlig fase. Målet nå er å jobbe tett med én eller flere
            norske aktører for å validere behov, installasjon, livevisning og
            dokumentasjon i praksis.
          </p>
        </div>

        <div class="border-l border-white/18 pl-8">
          <h3 class="text-2xl font-semibold">En god pilot har:</h3>
          <ul class="mt-6 grid gap-4 text-sm leading-relaxed text-white/68">
            <li>Et konkret sted der undervannsbilde gir bedre beslutninger.</li>
            <li>En tydelig operatør eller fagperson som kjenner problemet.</li>
            <li>Mulighet til å teste livevisning, opptak og enkel drift.</li>
            <li>Vilje til å gi ærlig tilbakemelding før produktet låses.</li>
          </ul>
          <a
            href="/contact"
            class="mt-7 inline-flex cursor-pointer items-center justify-center rounded-sm bg-[#f97316] px-5 py-3 text-sm font-semibold text-white transition-colors duration-200 hover:bg-[#fb8a3c]"
          >
            Snakk med oss om pilot
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
