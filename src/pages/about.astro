---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const values = [
  {
    title: "Robust først",
    text: "Zimo bygges for miljøer der utstyr må tåle vann, støy, røff håndtering og lange driftsperioder.",
  },
  {
    title: "Praktisk systemtenking",
    text: "Kundeverdien ligger i hele kjeden: kamera, gateway, livevisning, opptak, support og enkel drift.",
  },
  {
    title: "Kundestyrt utvikling",
    text: "Første versjon skal formes rundt reelle pilotbehov, ikke antakelser gjort på kontoret.",
  },
];
---

<BaseLayout
  title="Zimo — Om"
  description="Zimo er et norsk teknologiselskap som utvikler robuste undervannskamerasystemer."
>
  <Header />

  <main class="bg-[#05090b] text-white">
    <section class="zimo-shell grid gap-12 py-20 lg:grid-cols-[0.95fr_1.05fr] lg:items-end lg:py-28">
      <div>
        <p class="zimo-eyebrow">Om Zimo</p>
        <h1 class="mt-6 text-5xl font-semibold leading-tight tracking-tight md:text-7xl">
          Norsk undervannsteknologi i tidlig fase.
        </h1>
      </div>
      <p class="text-lg leading-relaxed text-white/70">
        Zimo utvikler robuste undervannskamerasystemer for miljøer der det er
        vanskelig å få pålitelig visuell innsikt. Første fokus er norske
        pilotkunder innen oppdrett, vanninfrastruktur og industriell inspeksjon.
      </p>
    </section>

    <section class="border-y border-white/10 bg-[#071923]">
      <div class="zimo-shell grid gap-8 py-10 md:grid-cols-3">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-white/42">Selskap</p>
          <p class="mt-2 text-lg font-semibold">Norsk og founder-led</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-white/42">Produkt</p>
          <p class="mt-2 text-lg font-semibold">Robuste undervannskamerasystemer</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-white/42">Fase</p>
          <p class="mt-2 text-lg font-semibold">Pilot og markedsvalidering</p>
        </div>
      </div>
    </section>

    <section class="zimo-shell py-24">
      <div class="grid gap-5 md:grid-cols-3">
        {values.map((item) => (
          <article class="zimo-panel rounded-xl p-6">
            <div class="h-1 w-10 bg-[#a8fff2]"></div>
            <h2 class="mt-6 text-2xl font-semibold">{item.title}</h2>
            <p class="mt-4 text-sm leading-relaxed text-white/64">{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="bg-[#0d2a35]">
      <div class="zimo-shell grid gap-10 py-24 lg:grid-cols-[1fr_0.9fr] lg:items-center">
        <div>
          <p class="zimo-eyebrow">Hvordan vi tenker</p>
          <h2 class="mt-5 text-4xl font-semibold tracking-tight md:text-6xl">
            Kameraet er produktet. Kontroll er verdien.
          </h2>
        </div>
        <p class="text-lg leading-relaxed text-white/72">
          Et undervannskamera blir først virkelig nyttig når bildet kan sees,
          deles, lagres og brukes i drift. Derfor bygger Zimo både hardware og
          den enkle operasjonelle flaten rundt kameraet.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
