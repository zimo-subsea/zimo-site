---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title,
  eyebrow,
  summary,
  tags = [],
  requestUrl = "/contact",
  image,
  specs = [],
  principles = [],
} = Astro.props;
---

<BaseLayout title={`Zimo — ${title}`} description={summary}>
  <Header />

  <main class="bg-white text-[#0b1114]">
    <section class="relative overflow-hidden bg-[linear-gradient(180deg,#ffffff_0%,#f6f8f8_100%)]">
      <div class="absolute inset-0 bg-[radial-gradient(900px_420px_at_72%_28%,rgba(34,184,170,0.12),transparent_68%)]"></div>
      <div class="zimo-shell relative grid gap-12 py-20 lg:grid-cols-[0.95fr_1.05fr] lg:items-center lg:py-28">
        <div>
          <p class="zimo-eyebrow">{eyebrow}</p>
          <h1 class="mt-6 text-5xl font-semibold leading-tight tracking-tight text-[#071923] md:text-7xl">
            {title}
          </h1>
          <p class="mt-7 max-w-2xl text-lg leading-relaxed text-[#516066]">
            {summary}
          </p>
          <div class="mt-8 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="rounded-md border border-[#d9e2e2] bg-white px-3 py-1.5 text-xs font-semibold text-[#516066]">
                {tag}
              </span>
            ))}
          </div>
          <div class="mt-10 flex flex-col gap-3 sm:flex-row">
            <a
              href={requestUrl}
              class="inline-flex items-center justify-center rounded-md bg-[#071923] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#0d2a35]"
            >
              Snakk om pilot
            </a>
            <a
              href="https://docs.zimo.no/"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-md border border-[#d9e2e2] bg-white px-6 py-3 text-sm font-semibold text-[#071923] transition hover:border-[#22b8aa]/60 hover:bg-[#eef5f5]"
            >
              Teknisk dokumentasjon
            </a>
          </div>
        </div>

        <div class="relative overflow-hidden rounded-2xl border border-[#d9e2e2] bg-white shadow-[0_24px_80px_rgba(7,25,35,0.08)]">
          <img
            src={image.src}
            alt={image.alt}
            class="h-[420px] w-full object-contain p-8"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <section class="border-y border-[#d9e2e2] bg-white">
      <div class="zimo-shell grid gap-0 py-2 md:grid-cols-5">
        {specs.map((item) => (
          <div class="border-b border-[#d9e2e2] py-5 md:border-b-0 md:border-r md:border-[#d9e2e2] md:px-5 last:md:border-r-0">
            <p class="text-xs uppercase tracking-[0.2em] text-[#516066]">{item.label}</p>
            <p class="mt-2 text-sm font-semibold text-[#071923]">{item.value}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="zimo-shell grid gap-12 py-24 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="zimo-eyebrow">Produktlogikk</p>
        <h2 class="mt-5 text-4xl font-semibold tracking-tight text-[#071923] md:text-6xl">
          Bygget for pilot, drift og læring.
        </h2>
      </div>

      <div class="grid gap-5">
        {principles.map((item) => (
          <article class="zimo-panel rounded-xl p-6">
            <h3 class="text-2xl font-semibold text-[#071923]">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[#516066]">{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="zimo-shell pb-24">
      <div class="border-t border-[#d9e2e2] pt-10">
        <div class="max-w-3xl text-base leading-relaxed text-[#516066]">
          <slot />
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
