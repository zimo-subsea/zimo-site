---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title,
  eyebrow,
  summary,
  tags = [],
  requestUrl = "/contact",
  image,
  specs = [],
  principles = [],
} = Astro.props;
---

<BaseLayout title={`Zimo — ${title}`} description={summary}>
  <Header />

  <main class="bg-[#05090b] text-white">
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(900px_420px_at_72%_28%,rgba(168,255,242,0.16),transparent_68%)]"></div>
      <div class="zimo-shell relative grid gap-12 py-20 lg:grid-cols-[0.95fr_1.05fr] lg:items-center lg:py-28">
        <div>
          <p class="zimo-eyebrow">{eyebrow}</p>
          <h1 class="mt-6 text-5xl font-semibold leading-tight tracking-tight md:text-7xl">
            {title}
          </h1>
          <p class="mt-7 max-w-2xl text-lg leading-relaxed text-white/70">
            {summary}
          </p>
          <div class="mt-8 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="rounded-md border border-white/12 bg-white/5 px-3 py-1.5 text-xs font-semibold text-white/68">
                {tag}
              </span>
            ))}
          </div>
          <div class="mt-10 flex flex-col gap-3 sm:flex-row">
            <a
              href={requestUrl}
              class="inline-flex items-center justify-center rounded-md bg-[#a8fff2] px-6 py-3 text-sm font-semibold text-[#05090b] transition hover:bg-[#c6fff7]"
            >
              Snakk om pilot
            </a>
            <a
              href="https://docs.zimo.no/"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-md border border-white/18 bg-white/5 px-6 py-3 text-sm font-semibold text-white/86 transition hover:border-white/36 hover:bg-white/9"
            >
              Teknisk dokumentasjon
            </a>
          </div>
        </div>

        <div class="relative overflow-hidden rounded-2xl border border-white/10 bg-[#07131a]">
          <img
            src={image.src}
            alt={image.alt}
            class="h-[420px] w-full object-contain p-8"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <section class="border-y border-white/10 bg-[#071923]">
      <div class="zimo-shell grid gap-0 py-2 md:grid-cols-5">
        {specs.map((item) => (
          <div class="border-b border-white/10 py-5 md:border-b-0 md:border-r md:border-white/10 md:px-5 last:md:border-r-0">
            <p class="text-xs uppercase tracking-[0.2em] text-white/40">{item.label}</p>
            <p class="mt-2 text-sm font-semibold text-white/82">{item.value}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="zimo-shell grid gap-12 py-24 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="zimo-eyebrow">Produktlogikk</p>
        <h2 class="mt-5 text-4xl font-semibold tracking-tight md:text-6xl">
          Bygget for pilot, drift og læring.
        </h2>
      </div>

      <div class="grid gap-5">
        {principles.map((item) => (
          <article class="zimo-panel rounded-xl p-6">
            <h3 class="text-2xl font-semibold">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-white/64">{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="zimo-shell pb-24">
      <div class="border-t border-white/10 pt-10">
        <div class="max-w-3xl text-base leading-relaxed text-white/72">
          <slot />
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
