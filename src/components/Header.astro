---
const nav = [
  { label: "System", href: "/products" },
  { label: "Pilot", href: "/#pilot" },
  { label: "Om Zimo", href: "/about" },
  { label: "Docs", href: "https://docs.zimo.no/", external: true },
  { label: "Kontakt", href: "/contact" },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-[#05090b]/78 backdrop-blur-xl">
  <div class="zimo-shell flex h-20 items-center justify-between">
    <a href="/" class="flex items-center gap-3" aria-label="Zimo hjem">
      <img
        src="/brand/ZiMO_full_white.svg"
        alt="Zimo"
        class="h-8 w-auto"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="hidden items-center gap-8 text-sm font-medium text-white/72 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noreferrer" : undefined}
          class="transition hover:text-white"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <a
        href="/contact"
        class="inline-flex items-center justify-center rounded-md border border-[#a8fff2]/35 bg-[#a8fff2]/10 px-4 py-2 text-sm font-semibold text-[#a8fff2] transition hover:border-[#a8fff2]/70 hover:bg-[#a8fff2]/16"
      >
        Start pilotdialog
      </a>
    </div>

    <button
      class="inline-flex h-11 w-11 items-center justify-center rounded-md border border-white/15 bg-white/5 text-white/80 transition hover:border-white/30 hover:text-white md:hidden"
      type="button"
      aria-label="Åpne meny"
      aria-expanded="false"
      data-mobile-toggle
    >
      <svg
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M4 7h16" />
        <path d="M4 12h16" />
        <path d="M4 17h16" />
      </svg>
    </button>
  </div>

  <div class="zimo-shell hidden pb-5 md:hidden" data-mobile-menu data-open="false">
    <div class="zimo-panel grid gap-2 rounded-xl p-3 text-sm text-white/82">
      {nav.map((item) => (
        <a
          href={item.href}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noreferrer" : undefined}
          class="flex items-center justify-between rounded-lg px-3 py-3 transition hover:bg-white/7 hover:text-white"
        >
          <span>{item.label}</span>
          <span class="text-white/35">→</span>
        </a>
      ))}
      <a
        href="/contact"
        class="mt-2 inline-flex items-center justify-center rounded-md bg-[#a8fff2] px-4 py-3 text-sm font-semibold text-[#05090b]"
      >
        Start pilotdialog
      </a>
    </div>
  </div>

  <script is:inline>
    (() => {
      const mobileToggle = document.querySelector("[data-mobile-toggle]");
      const mobileMenu = document.querySelector("[data-mobile-menu]");
      if (!mobileToggle || !mobileMenu) return;

      const setOpen = (isOpen) => {
        mobileMenu.dataset.open = isOpen ? "true" : "false";
        mobileToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
        mobileMenu.classList.toggle("hidden", !isOpen);
      };

      setOpen(false);
      mobileToggle.addEventListener("click", () => {
        setOpen(mobileMenu.dataset.open !== "true");
      });

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        if (
          !event.target.closest("[data-mobile-menu]") &&
          !event.target.closest("[data-mobile-toggle]")
        ) {
          setOpen(false);
        }
      });
    })();
  </script>
</header>
