---
const { tone = "light" } = Astro.props;

const nav = [
  { label: "Hovedside", href: "/" },
  { label: "Pilotprosjekt", href: "/#pilot" },
];

const isDark = tone === "dark";
---

<header
  class:list={[
    "z-50 border-b backdrop-blur-xl",
    isDark
      ? "absolute inset-x-0 top-0 border-white/10 bg-[#071923]/42 text-white"
      : "sticky top-0 border-[#d9e2e2] bg-white/88 text-[#071923]",
  ]}
>
  <div class="zimo-shell flex h-[5.5rem] items-center justify-between">
    <a href="/" class="flex items-center" aria-label="Zimo hjem">
      <img
        src="/brand/ZiMO_full_white.svg"
        alt=""
        class:list={[
          "h-10 w-auto",
          !isDark && "[filter:brightness(0)]",
        ]}
        loading="eager"
        decoding="async"
      />
    </a>

    <nav
      class:list={[
        "hidden items-center gap-8 text-sm font-semibold md:flex",
        isDark ? "text-white/88" : "text-[#516066]",
      ]}
    >
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "inline-flex cursor-pointer items-center gap-2 transition-colors duration-200",
            isDark ? "hover:text-[#a8fff2]" : "hover:text-[#071923]",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-6 md:flex">
      <a
        href="https://docs.zimo.no/"
        target="_blank"
        rel="noreferrer"
        class:list={[
          "text-sm font-semibold transition-colors duration-200",
          isDark ? "text-white/78 hover:text-white" : "text-[#516066] hover:text-[#071923]",
        ]}
      >
        Docs
      </a>
      <a
        href="/contact"
        class:list={[
          "inline-flex cursor-pointer items-center justify-center text-sm font-semibold transition-colors duration-200",
          isDark ? "text-white hover:text-[#a8fff2]" : "text-[#071923] hover:text-[#0d776f]",
        ]}
      >
        Kontakt
      </a>
    </div>

    <button
      class:list={[
        "inline-flex h-11 w-11 cursor-pointer items-center justify-center rounded-sm border transition-colors duration-200 md:hidden",
        isDark
          ? "border-white/18 bg-white/8 text-white hover:border-[#a8fff2]/55"
          : "border-[#d9e2e2] bg-white text-[#071923] hover:border-[#22b8aa]/55",
      ]}
      type="button"
      aria-label="Åpne meny"
      aria-expanded="false"
      data-mobile-toggle
    >
      <svg
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M4 7h16" />
        <path d="M4 12h16" />
        <path d="M4 17h16" />
      </svg>
    </button>
  </div>

  <div class="zimo-shell hidden pb-5 md:hidden" data-mobile-menu data-open="false">
    <div
      class:list={[
        "grid gap-2 rounded-sm border p-3 text-sm shadow-[0_22px_80px_rgba(0,0,0,0.18)]",
        isDark
          ? "border-white/12 bg-[#071923]/94 text-white/76"
          : "border-[#d9e2e2] bg-white text-[#516066]",
      ]}
    >
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "flex cursor-pointer items-center justify-between rounded-sm px-3 py-3 transition-colors duration-200",
            isDark ? "hover:bg-white/8 hover:text-white" : "hover:bg-[#eef5f5] hover:text-[#071923]",
          ]}
        >
          <span>{item.label}</span>
          <span class={isDark ? "text-[#a8fff2]" : "text-[#0d776f]/60"}>→</span>
        </a>
      ))}
      <a
        href="https://docs.zimo.no/"
        target="_blank"
        rel="noreferrer"
        class:list={[
          "flex cursor-pointer items-center justify-between rounded-sm px-3 py-3 transition-colors duration-200",
          isDark ? "hover:bg-white/8 hover:text-white" : "hover:bg-[#eef5f5] hover:text-[#071923]",
        ]}
      >
        <span>Docs</span>
        <span class={isDark ? "text-[#a8fff2]" : "text-[#0d776f]/60"}>→</span>
      </a>
      <a
        href="/contact"
        class:list={[
          "flex cursor-pointer items-center justify-between rounded-sm px-3 py-3 font-semibold transition-colors duration-200",
          isDark ? "hover:bg-white/8 hover:text-white" : "hover:bg-[#eef5f5] hover:text-[#071923]",
        ]}
      >
        <span>Kontakt</span>
        <span class={isDark ? "text-[#a8fff2]" : "text-[#0d776f]/60"}>→</span>
      </a>
    </div>
  </div>

  <script is:inline>
    (() => {
      const mobileToggle = document.querySelector("[data-mobile-toggle]");
      const mobileMenu = document.querySelector("[data-mobile-menu]");
      if (!mobileToggle || !mobileMenu) return;

      const setOpen = (isOpen) => {
        mobileMenu.dataset.open = isOpen ? "true" : "false";
        mobileToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
        mobileMenu.classList.toggle("hidden", !isOpen);
      };

      setOpen(false);
      mobileToggle.addEventListener("click", () => {
        setOpen(mobileMenu.dataset.open !== "true");
      });

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        if (
          !event.target.closest("[data-mobile-menu]") &&
          !event.target.closest("[data-mobile-toggle]")
        ) {
          setOpen(false);
        }
      });
    })();
  </script>
</header>
